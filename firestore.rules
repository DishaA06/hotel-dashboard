// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only the authenticated user can read their own profile
    // Admins can read all profiles
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId
      );
      // Only allow writes through Admin SDK (seeding script)
      allow write: if false;
    }

    // Tasks: any authenticated user can read and write
    // (Role-based restrictions are enforced in the UI)
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }
  }
}
